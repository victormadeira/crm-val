{
  "expo": {
    "name": "Valparaíso CRM",
    "slug": "valparaiso-crm",
    "scheme": "valparaiso",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "bundleIdentifier": "com.valparaisoadventurepark.crm",
      "supportsTablet": true,
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Usado para gravar áudios de atendimento via WhatsApp.",
        "NSCameraUsageDescription": "Usado para enviar fotos em atendimentos via WhatsApp.",
        "NSPhotoLibraryUsageDescription": "Usado para anexar fotos em atendimentos via WhatsApp."
      }
    },
    "android": {
      "package": "com.valparaisoadventurepark.crm",
      "adaptiveIcon": {
        "backgroundColor": "#006938"
      },
      "permissions": ["NOTIFICATIONS", "RECEIVE_BOOT_COMPLETED"]
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "color": "#ff0030"
        }
      ]
    ],
    "extra": {
      "apiBaseUrl": "http://localhost:3000"
    }
  }
}
