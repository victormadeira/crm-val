# ======================================================================
# Valparaíso CRM — exemplo de ambiente
# Copie para .env e preencha. Nunca commitar .env real.
# ======================================================================

NODE_ENV=development
PORT=3000
LOG_LEVEL=debug

# ---- Banco ----
POSTGRES_DB=valparaiso
POSTGRES_USER=valparaiso
POSTGRES_PASSWORD=change-me-local-only
POSTGRES_PORT=5432
DATABASE_URL=postgresql://valparaiso:change-me-local-only@localhost:5432/valparaiso?schema=public

# ---- Redis ----
REDIS_PASSWORD=change-me-local-only
REDIS_PORT=6379
REDIS_URL=redis://:change-me-local-only@localhost:6379

# ---- JWT ----
# Gere: openssl rand -base64 48
JWT_ACCESS_SECRET=REPLACE-32-PLUS-BYTES-OF-RANDOMNESS-ABCDEFGH
JWT_ACCESS_TTL=15m
JWT_REFRESH_SECRET=REPLACE-32-PLUS-BYTES-OF-RANDOMNESS-IJKLMNOP
JWT_REFRESH_TTL=30d

# ---- Crypto mestra (AES-256-GCM) ----
# Gere: openssl rand -base64 32
ENCRYPTION_KEY=REPLACE-32-BYTES-BASE64-XXXXXXXXXXXXXXXXXXXX=

# ---- CORS ----
CORS_ORIGINS=http://localhost:5173,http://localhost:4173

# ---- Meta Graph API (WhatsApp Cloud API direto) ----
META_GRAPH_API_BASE=https://graph.facebook.com
META_GRAPH_API_VERSION=v19.0

# ---- Caddy (prod) ----
CADDY_DOMAIN=localhost
